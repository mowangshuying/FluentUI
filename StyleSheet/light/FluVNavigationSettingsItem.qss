FluVNavigationSettingsItem {
    background-color: transparent;
    border-radius: 4px;
}

FluVNavigationSettingsItem:hover {
    background-color: rgba(0, 0, 0, 0.04);
    border-radius: 4px;
}

#icon {
    border: none;
    background-color: transparent;
}

#label {
    background-color: transparent;
    font-size: 14px;
    color: #1a1a1a;
}