FluGalleryWindow {
    background-color: rgb(33, 37, 43);
}

#titleBar {
    color: white;
    background-color: rgb(33, 37, 43);
}

FluGalleryWindow[horizontalNav="true"] FluWidget {
    border: none;
    border-radius: 0;
    border-top-left-radius: 0;
    border-top-right-radius: 0;
}

#horizontalNavView {
    background-color: rgb(33, 37, 43);
    border-bottom: 1px solid rgb(55, 58, 63);
}